{
  "version": 2,
  "rules": [
    {
      "id": "12306_ticket_short",
      "target_card": "TrainTicket",
      "priority": 100,
      "fast_fail": {
        "signature_equals": "12306"
      },
      "conditions": {
        "content_regex": "(?<passenger>[\u4e00-\u9fa5]+)购票成功，(?<date>\d{1,2}月\d{1,2}日)\s*(?<trainNo>[A-Z0-9]+)次，(?<departureStation>.+?)站(?<departureTime>\d{2}:\d{2})开"
      }
    },
    {
      "id": "train_ticket_huilianyi",
      "target_card": "TrainTicket",
      "priority": 90,
      "fast_fail": {
        "signature_equals": "汇联易甄选"
      },
      "conditions": {
        "content_regex": "(?<date>\d{4}-\d{2}-\d{2}) (?<departureTime>\d{2}:\d{2}:\d{2})出发，(?<departureStation>[^—]+)—(?<arrivalStation>[^，]+)，(?<trainNo>[A-Z0-9]+)，(?:检票口：(?<gate>[A-Z0-9]+)，)?(?<passenger>[\u4e00-\u9fa5]+) .*?(?<seat>\d+车厢\w+号)"
      }
    },
    {
      "id": "express_delivery_cainiao",
      "target_card": "ExpressDelivery",
      "priority": 85,
      "fast_fail": {
        "keywords": [
          "取件",
          "驿站",
          "快递"
        ]
      },
      "conditions": {
        "content_regex": "【(?<station>.*?)】.*?(?<company>[\u4e00-\u9fa5]{2,4}快递|顺丰).*?(?:暂存|到达|放置)至(?<location>[^，。]+)[，。].*?(?:取件码|提货码|凭证)[：:]?(?<code>[a-zA-Z0-9-]+)(?:，.*?于(?<time>[^前]+)前)?"
      }
    },
    {
      "id": "bank_transaction_fail",
      "target_card": "BankTransaction",
      "priority": 82,
      "fast_fail": {
        "keywords": [
          "失败"
        ]
      },
      "conditions": {
        "content_regex": "尾号\*?(?<account>\d{4}).*?(?<type>支付|消费|扣款|交易).*?(?<amount>[0-9,.]+).*?(?<status>失败).*?原因[：:]?(?<reason>[^，。]+)"
      }
    },
    {
      "id": "bank_transaction_cmb",
      "target_card": "BankTransaction",
      "priority": 80,
      "fast_fail": {
        "signature_equals": "招商银行"
      },
      "conditions": {
        "content_regex": "账户(?<account>\d{4})于(?<date>\d{2}月\d{2}日\d{2}:\d{2}).*?(?<type>扣款|消费|入账|支出|存入|转账|收入).*?(?<amount>[0-9,.]+)(?<currency>元)(?<details>.*)"
      }
    },
    {
      "id": "bank_transaction_comm",
      "target_card": "BankTransaction",
      "priority": 79,
      "fast_fail": {
        "signature_equals": "交通银行"
      },
      "conditions": {
        "content_regex": "尾号\*?(?<account>\d{4}).*?(?<date>\d{2}月\d{2}日\d{2}：\d{2})在(?<details>.*?)(?<type>支付|消费|扣款)(?<amount>[0-9,.]+)(?<currency>元)"
      }
    },
    {
      "id": "phone_recharge_unicom",
      "target_card": "PhoneRecharge",
      "priority": 70,
      "fast_fail": {
        "signature_equals": "中国联通"
      },
      "conditions": {
        "content_regex": "于(?<date>\d{2}日\d{2}时\d{2}分)(?:交费|充值)(?<amount>[0-9,.]+)元，账户当前可用余额为(?<balance>[0-9,.]+)元"
      }
    },
    {
      "id": "verification_code_general",
      "target_card": "VerificationCode",
      "priority": 10,
      "fast_fail": {
        "keywords": [
          "验证码",
          "动态码",
          "校验码",
          "code"
        ]
      },
      "conditions": {
        "content_regex": "(?i)(?:验证码|动态码|校验码|code).*?(?<code>[0-9a-zA-Z]{4,8})"
      }
    }
  ]
}